      "property": "minecraft:has_component",
      "component": "bren:has_magazine",
      "on_true": {
        "type": "minecraft:model",
        "model": "bren:item/smg_1"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "bren:item/smg_0"
      }
    }
